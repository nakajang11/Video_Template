{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Template Pipeline Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "job_id",
    "renderer",
    "review_status",
    "package_dir",
    "caller_context_echo",
    "source_summary",
    "package_summary",
    "artifacts",
    "shotstack_smoke",
    "validation",
    "notes"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "review_required",
        "validation_failed",
        "input_error",
        "internal_error"
      ]
    },
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "renderer": {
      "type": "string",
      "enum": [
        "shotstack",
        "remotion",
        "unknown"
      ]
    },
    "review_status": {
      "type": "string",
      "minLength": 1
    },
    "package_dir": {
      "type": "string",
      "minLength": 1
    },
    "caller_context_echo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "template_type",
        "source_platform",
        "source_trend_video_id",
        "preferred_renderer",
        "step1_hint_summary",
        "step2_hint_summary",
        "operator_notes_summary"
      ],
      "properties": {
        "template_type": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_platform": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_trend_video_id": {
          "type": [
            "string",
            "number",
            "integer",
            "null"
          ]
        },
        "preferred_renderer": {
          "type": "string",
          "enum": [
            "auto",
            "shotstack",
            "remotion"
          ]
        },
        "step1_hint_summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "step2_hint_summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "operator_notes_summary": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "source_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_video",
        "duration_sec",
        "width",
        "height",
        "scene_count"
      ],
      "properties": {
        "source_video": {
          "type": [
            "string",
            "null"
          ]
        },
        "duration_sec": {
          "type": [
            "number",
            "null"
          ]
        },
        "width": {
          "type": [
            "number",
            "null"
          ]
        },
        "height": {
          "type": [
            "number",
            "null"
          ]
        },
        "scene_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "package_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scene_count",
        "slot_count",
        "text_slot_count",
        "media_slot_count",
        "renderer"
      ],
      "properties": {
        "scene_count": {
          "type": "integer",
          "minimum": 0
        },
        "slot_count": {
          "type": "integer",
          "minimum": 0
        },
        "text_slot_count": {
          "type": "integer",
          "minimum": 0
        },
        "media_slot_count": {
          "type": "integer",
          "minimum": 0
        },
        "renderer": {
          "type": "string",
          "enum": [
            "shotstack",
            "remotion",
            "unknown"
          ]
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "analysis",
        "story",
        "variable_map",
        "blueprint",
        "manifest",
        "shotstack",
        "remotion_package",
        "source_audio",
        "template_contract",
        "package_archive",
        "shotstack_smoke_result",
        "shotstack_smoke_compare",
        "shotstack_smoke_contact_sheet",
        "shotstack_smoke_render",
        "prompt_files"
      ],
      "properties": {
        "analysis": {
          "type": [
            "string",
            "null"
          ]
        },
        "story": {
          "type": [
            "string",
            "null"
          ]
        },
        "variable_map": {
          "type": [
            "string",
            "null"
          ]
        },
        "blueprint": {
          "type": [
            "string",
            "null"
          ]
        },
        "manifest": {
          "type": [
            "string",
            "null"
          ]
        },
        "shotstack": {
          "type": [
            "string",
            "null"
          ]
        },
        "remotion_package": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_audio": {
          "type": [
            "string",
            "null"
          ]
        },
        "template_contract": {
          "type": [
            "string",
            "null"
          ]
        },
        "package_archive": {
          "type": [
            "string",
            "null"
          ]
        },
        "shotstack_smoke_result": {
          "type": [
            "string",
            "null"
          ]
        },
        "shotstack_smoke_compare": {
          "type": [
            "string",
            "null"
          ]
        },
        "shotstack_smoke_contact_sheet": {
          "type": [
            "string",
            "null"
          ]
        },
        "shotstack_smoke_render": {
          "type": [
            "string",
            "null"
          ]
        },
        "prompt_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "shotstack_smoke": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "mode",
        "limit",
        "attempted",
        "status",
        "render_url",
        "render_path",
        "improvement_notes",
        "error"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "enum": [
            "off",
            "render-once"
          ]
        },
        "limit": {
          "type": "integer",
          "const": 1
        },
        "attempted": {
          "type": "boolean"
        },
        "status": {
          "type": "string"
        },
        "render_url": {
          "type": [
            "string",
            "null"
          ]
        },
        "render_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "improvement_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "error": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passed",
        "errors",
        "warnings"
      ],
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
