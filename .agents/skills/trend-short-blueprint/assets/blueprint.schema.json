{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Trend Short Blueprint",
  "type": "object",
  "required": [
    "contract_version",
    "job_id",
    "source_video",
    "renderer",
    "audio",
    "review_status",
    "scene_order",
    "scenes"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "minLength": 1
    },
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "source_video": {
      "type": "string",
      "minLength": 1
    },
    "renderer": {
      "type": "string",
      "enum": [
        "shotstack",
        "remotion"
      ]
    },
    "audio": {
      "type": "object",
      "required": [
        "strategy",
        "source_file",
        "shotstack_merge_key"
      ],
      "properties": {
        "strategy": {
          "type": "string",
          "enum": [
            "use_input_audio"
          ]
        },
        "source_file": {
          "type": "string",
          "const": "source_audio.mp3"
        },
        "shotstack_merge_key": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        }
      },
      "additionalProperties": true
    },
    "review_status": {
      "type": "string",
      "enum": [
        "review_required",
        "approved_for_packaging"
      ]
    },
    "remotion_package": {
      "type": "object",
      "properties": {
        "package_dir": {
          "type": "string"
        },
        "entry_file": {
          "type": "string"
        },
        "composition_id": {
          "type": "string"
        },
        "props_file": {
          "type": "string"
        },
        "editable_props": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "scene_order": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^scene_[0-9]{3}$"
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "scene_id",
          "duration_sec",
          "story_role",
          "cast",
          "locks",
          "variables",
          "startframe",
          "video"
        ],
        "properties": {
          "scene_id": {
            "type": "string",
            "pattern": "^scene_[0-9]{3}$"
          },
          "duration_sec": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "story_role": {
            "type": "string"
          },
          "cast": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "locks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "variables": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "startframe": {
            "type": "object",
            "required": [
              "required",
              "model",
              "prompt_file",
              "reference_assets"
            ],
            "properties": {
              "required": {
                "type": "boolean"
              },
              "model": {
                "type": "string"
              },
              "prompt_file": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "reference_assets": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          },
          "video": {
            "type": "object",
            "required": [
              "mode",
              "model",
              "prompt_file",
              "reference_assets"
            ],
            "properties": {
              "mode": {
                "type": "string",
                "enum": [
                  "generate",
                  "motion-control",
                  "still-image-effect",
                  "input-extract",
                  "reuse-generated",
                  "code-driven"
                ]
              },
              "model": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "prompt_file": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "reference_assets": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          },
          "remotion_sequence": {
            "type": "object",
            "properties": {
              "sequence_id": {
                "type": "string"
              },
              "start_frame": {
                "type": "integer",
                "minimum": 0
              },
              "duration_frames": {
                "type": "integer",
                "minimum": 1
              },
              "editable_props": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          },
          "shotstack": {
            "type": "object",
            "required": [
              "asset_type",
              "alias",
              "merge_key",
              "clip_length_sec",
              "text_overlays"
            ],
            "properties": {
              "asset_type": {
                "type": "string",
                "enum": [
                  "video",
                  "image"
                ]
              },
              "alias": {
                "type": "string",
                "pattern": "^[A-Z0-9_]+$"
              },
              "merge_key": {
                "type": "string",
                "pattern": "^[A-Z0-9_]+$"
              },
              "clip_length_sec": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "overlay_layers": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "asset_type",
                    "merge_key",
                    "relative_start_sec",
                    "duration_sec",
                    "position",
                    "width",
                    "height"
                  ],
                  "properties": {
                    "asset_type": {
                      "type": "string",
                      "enum": [
                        "image",
                        "video"
                      ]
                    },
                    "merge_key": {
                      "type": "string",
                      "pattern": "^[A-Z0-9_]+$"
                    },
                    "relative_start_sec": {
                      "type": "number",
                      "minimum": 0
                    },
                    "duration_sec": {
                      "type": "number",
                      "exclusiveMinimum": 0
                    },
                    "position": {
                      "type": "string"
                    },
                    "width": {
                      "type": "number",
                      "exclusiveMinimum": 0
                    },
                    "height": {
                      "type": "number",
                      "exclusiveMinimum": 0
                    },
                    "offset": {
                      "type": "object"
                    }
                  },
                  "additionalProperties": true
                }
              },
              "text_overlays": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "text_key"
                  ],
                  "properties": {
                    "text_key": {
                      "type": "string",
                      "pattern": "^[A-Z0-9_]+$"
                    },
                    "source_geometry": {
                      "type": "object",
                      "properties": {
                        "design_role": {
                          "type": "string",
                          "enum": [
                            "boxed_label",
                            "caption_bar",
                            "plain_stroked_text"
                          ]
                        },
                        "reference_asset": {
                          "type": "string"
                        },
                        "anchor": {
                          "type": "string"
                        },
                        "editor_preview_strategy": {
                          "type": "string",
                          "enum": [
                            "editable_over_box_background",
                            "editable_on_clean_plate",
                            "manual_review_required"
                          ]
                        },
                        "font_candidates": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "font_size_hint": {
                          "type": "number",
                          "exclusiveMinimum": 0
                        },
                        "stroke_px": {
                          "type": "number",
                          "minimum": 0
                        },
                        "clean_plate_file": {
                          "type": "string"
                        },
                        "box_bbox_px": {
                          "type": "object",
                          "properties": {
                            "x": {
                              "type": "number"
                            },
                            "y": {
                              "type": "number"
                            },
                            "width": {
                              "type": "number",
                              "exclusiveMinimum": 0
                            },
                            "height": {
                              "type": "number",
                              "exclusiveMinimum": 0
                            }
                          },
                          "additionalProperties": true
                        },
                        "text_bbox_px": {
                          "type": "object",
                          "properties": {
                            "x": {
                              "type": "number"
                            },
                            "y": {
                              "type": "number"
                            },
                            "width": {
                              "type": "number",
                              "exclusiveMinimum": 0
                            },
                            "height": {
                              "type": "number",
                              "exclusiveMinimum": 0
                            }
                          },
                          "additionalProperties": true
                        },
                        "padding_px": {
                          "type": "object",
                          "properties": {
                            "top": {
                              "type": "number",
                              "minimum": 0
                            },
                            "right": {
                              "type": "number",
                              "minimum": 0
                            },
                            "bottom": {
                              "type": "number",
                              "minimum": 0
                            },
                            "left": {
                              "type": "number",
                              "minimum": 0
                            }
                          },
                          "additionalProperties": true
                        }
                      },
                      "additionalProperties": true
                    }
                  },
                  "additionalProperties": true
                }
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
