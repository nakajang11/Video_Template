{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Trend Short Analysis",
  "type": "object",
  "required": [
    "job_id",
    "source_video",
    "media",
    "analysis_confidence",
    "scenes"
  ],
  "properties": {
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "source_video": {
      "type": "string",
      "minLength": 1
    },
    "media": {
      "type": "object",
      "required": [
        "duration_sec",
        "width",
        "height"
      ],
      "properties": {
        "duration_sec": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "fps": {
          "type": [
            "number",
            "null"
          ]
        },
        "orientation": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "analysis_confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "story_summary": {
      "type": "string"
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "scene_id",
          "start_sec",
          "end_sec",
          "duration_sec",
          "summary",
          "characters",
          "camera",
          "evidence_confidence"
        ],
        "properties": {
          "scene_id": {
            "type": "string",
            "pattern": "^scene_[0-9]{3}$"
          },
          "start_sec": {
            "type": "number",
            "minimum": 0
          },
          "end_sec": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "duration_sec": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "characters": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "camera": {
            "type": "object",
            "properties": {
              "framing": {
                "type": "string"
              },
              "movement": {
                "type": "string"
              },
              "stability": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          "on_screen_text": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence_confidence": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
