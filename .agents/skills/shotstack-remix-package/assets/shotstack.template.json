{
  "timeline": {
    "background": "#000000",
    "tracks": [
      {
        "clips": [
          {
            "asset": {
              "type": "audio",
              "src": "{{ SOURCE_AUDIO_MP3 }}",
              "volume": 1
            },
            "start": 0,
            "length": 5.6
          }
        ]
      },
      {
        "clips": [
          {
            "alias": "SCENE_001",
            "asset": {
              "type": "video",
              "src": "{{ SCENE_001_MEDIA }}"
            },
            "start": "auto",
            "length": 3.2,
            "fit": "cover"
          },
          {
            "alias": "SCENE_002",
            "asset": {
              "type": "image",
              "src": "{{ SCENE_002_IMAGE }}"
            },
            "start": "auto",
            "length": 2.4,
            "effect": "zoomInSlow"
          }
        ]
      },
      {
        "clips": [
          {
            "asset": {
              "type": "image",
              "src": "{{ SCENE_001_OVERLAY_001_IMAGE }}"
            },
            "start": 0.4,
            "length": 1.2,
            "position": "center",
            "offset": {
              "x": 0,
              "y": -0.35
            },
            "width": 0.28,
            "height": 0.22
          }
        ]
      },
      {
        "clips": [
          {
            "asset": {
              "type": "text",
              "text": "{{ SCENE_001_TITLE }}",
              "font": {
                "family": "Montserrat",
                "color": "#ffffff",
                "size": 72
              },
              "alignment": {
                "horizontal": "center",
                "vertical": "center"
              }
            },
            "start": "alias://SCENE_001",
            "length": "alias://SCENE_001",
            "position": "center"
          }
        ]
      }
    ]
  },
  "output": {
    "format": "mp4",
    "fps": 25,
    "size": {
      "width": 1080,
      "height": 1920
    },
    "destinations": [
      {
        "provider": "shotstack"
      }
    ]
  },
  "merge": [
    {
      "find": "SOURCE_AUDIO_MP3",
      "replace": "https://example.com/source_audio.mp3"
    },
    {
      "find": "SCENE_001_MEDIA",
      "replace": "https://example.com/scene_001.mp4"
    },
    {
      "find": "SCENE_002_IMAGE",
      "replace": "https://example.com/scene_002.png"
    },
    {
      "find": "SCENE_001_OVERLAY_001_IMAGE",
      "replace": "https://example.com/scene_001_overlay_001.png"
    },
    {
      "find": "SCENE_001_TITLE",
      "replace": "Replace me"
    }
  ]
}
